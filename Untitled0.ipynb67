        "# fazer um programa que converte KM em metros\n",
        "\n",
        "# entrada\n",
        "a = int(input(\"digite um primeiro valor em metros \"))\n",
        "b = int (input(\"digite um segundo valor em km \"))\n",
        "\n",
        "# processamento\n",
        "a = a / 1000\n",
        "b = b * 1000\n",
        "\n",
        "#saida\n",
        "print(f\"o seu primeiro valor em km é igual a {a}\")\n",
        "print(f\"o seu segundo valor em metros é igual a {b} \")"
      ],
