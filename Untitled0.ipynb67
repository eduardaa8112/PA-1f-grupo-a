      "cell_type": "code",
      "source": [
        "# operadores\n",
        "a = int(input(\"digite um numero : \"))\n",
        "b = int(input(\"digite outro numero : \"))\n",
        "\n",
        "#peocessamento\n",
        "\n",
        "# comparação\n",
        "igual = a == b\n",
        "\n",
        "\n",
        "maior = a > b\n",
        "menor = a < b\n",
        "maiorigual = a >= b\n",
        "menorigual = a <= b\n",
        "\n",
        " #saida\n",
        "print(maior)\n",
        "print(menor)\n",
        "print(menorigual)\n",
        "print(maiorigual)\n"
      ],
      "metadata": {
